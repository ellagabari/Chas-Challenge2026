# Copy to .env when running the backend locally (e.g. npm run dev from ./backend).
# In Docker Compose, DATABASE_URL and JWT_SECRET are injected from the root .env — this file is not required inside the container unless you mount it.

JWT_SECRET=
DATABASE_URL=
GOOGLE_CLIENT_ID=
PORT=3000

# Garage S3-compatible object storage
S3_URL=                 # e.g. https://group-2-chas-challenge-2026.hel1.your-objectstorage.com
access_key_S3=
secret_key_S3=
S3_BUCKET=              # e.g. reports
S3_REGION=garage        # Garage uses a dummy region; keep as "garage" unless told otherwise
