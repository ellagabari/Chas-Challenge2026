# Rename or copy this file to `.env` in the repo root for Docker Compose (`docker-compose.local.yml`).
# Postgres only reads POSTGRES_* on first database init; if you change passwords later, reset the `db_data` volume or keep the old password.

POSTGRES_PASSWORD=""
POSTGRES_USER=""
POSTGRES_DB=""
POSTGRES_URL=""
JWT_SECRET=""
GOOGLE_CLIENT_ID=""

# Garage S3-compatible object storage (required for photo uploads)
S3_URL=""          # e.g. https://group-2-chas-challenge-2026.hel1.your-objectstorage.com
S3_BUCKET=""       # e.g. reports
S3_REGION="garage" # Garage uses a dummy region; keep as "garage" unless told otherwise
access_key_S3=""
secret_key_S3=""
