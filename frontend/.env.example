# Copy to .env (Vite reads VITE_* at dev server start). With Docker, ./frontend is mounted so a local .env is picked up by the frontend container.
#
# VITE_API_URL: base URL prepended to every /api/* request.
#   - Leave empty (or omit) in production: nginx proxies /api/* to the backend automatically.
#   - Set to http://localhost:3000 for local dev when running the backend directly (no Docker proxy).
VITE_API_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=
